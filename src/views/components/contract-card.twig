{# Contract Card molecule #}
{#
@params: {
  contract: {
    id, tabId, logo, title, price, priceUnit, duration, tags[], verified, description
  }
}
#}
{% import 'ui/badge.twig' as badge %}

<article class="contract-card js-contract-card"
  data-id="{{ contract.id }}"
  data-tab-id="{{ contract.tabId }}"
  data-title="{{ contract.title | lower }}"
  data-description="{{ contract.description | lower }}">
  <div class="contract-card__header">
    <img
      class="contract-card__logo"
      src="{{ contract.logo }}"
      alt="{{ contract.title }}"
      width="32"
      height="32"
      loading="lazy"
    >
  </div>

  <span class="contract-card__title">{{ contract.title }}</span>

  <p class="contract-card__price">
    {{ contract.price }}
    <span class="contract-card__price-unit">/ {{ contract.priceUnit }}</span>
  </p>

  <p class="contract-card__duration">
    <span class="contract-card__clock">⏱</span>
    {{ contract.duration }}
  </p>

  <div class="contract-card__badges">
    {% for tag in contract.tags %}
      {{ badge.render({ inner: tag }) }}
    {% endfor %}
    {% if contract.verified %}
      {{ badge.render({ inner: 'Verified', variant: 'verified' }) }}
    {% endif %}
  </div>

  <p class="contract-card__description">{{ contract.description }}</p>

  <span class="contract-card__rightCorner" ></span>
  <span class="contract-card__leftCorner" ></span>

  <span class="contract-card__arrow" aria-hidden="true">
    <img src="img/content/contract/Vector.png" alt="" width="25" height="20">
  </span>
</article>
