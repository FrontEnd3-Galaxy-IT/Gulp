{% import 'ui/logo.twig' as logo %}
{% import 'ui/buttons.twig' as btn %}
{% import 'ui/links.twig' as link %}

<header class="site-header js-site-header">
  <div class="container">
    <div class="site-header__inner">
      {{ logo.render({ href: 'index.html' }) }}

      <nav class="site-header__nav">
        {{ link.nav({ inner: 'Home', href: 'index.html', class: 'js-nav-link' }) }}
        {{ link.nav({ inner: 'How It Works', href: 'index.html#how-it-works', class: 'js-nav-link' }) }}
        {{ link.nav({ inner: 'Latest Contracts Post', href: 'index.html#latest-contracts', class: 'js-nav-link' }) }}
        {{ link.nav({ inner: 'People Loved us!', href: 'index.html#people', class: 'js-nav-link' }) }}
      </nav>

      <div class="site-header__actions">
        {{ link.nav({ inner: 'Login', href: '#' }) }}
        {{ btn.outlined({ inner: 'Sign Up' }) }}
      </div>

      <button class="site-header__burger js-burger-btn" type="button" aria-label="Toggle menu">
        <span></span>
        <span></span>
        <span></span>
      </button>
    </div>
  </div>

  <div class="site-header__drawer js-burger-drawer">
    {{ link.nav({ inner: 'Home', href: 'index.html', class: 'js-nav-link' }) }}
    {{ link.nav({ inner: 'How It Works', href: 'index.html#how-it-works', class: 'js-nav-link' }) }}
    {{ link.nav({ inner: 'Latest Contracts Post', href: 'index.html#latest-contracts', class: 'js-nav-link' }) }}
    {{ link.nav({ inner: 'People Loved us!', class: 'js-nav-link' }) }}
    {{ btn.outlined({ inner: 'Login' }) }}
    {{ btn.primary({ inner: 'Sign Up' }) }}
  </div>
</header>
