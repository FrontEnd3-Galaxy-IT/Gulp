    <div class="site-footer__main">
      {{ logo.render({ href: 'index.html' }) }}
      <div class="site-footer__socials">
        <a class="site-footer__social" href="#" aria-label="X">
          <img src="img/content/footer/Vector.png" alt="" width="15" height="15">
        </a>
        <a class="site-footer__social" href="#" aria-label="LinkedIn">
          <img src="img/content/footer/linked.png" alt="" width="32" height="32">
        </a>
        <a class="site-footer__social" href="#" aria-label="Instagram">
          <img src="img/content/footer/inst.png" alt="" width="32" height="32">
